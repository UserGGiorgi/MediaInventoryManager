@model List<MediaInventoryManager.Models.Product>

<div id="product-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var product in Model)
    {
        <div class="border rounded-lg p-4 shadow-sm bg-white">
            @if (!string.IsNullOrEmpty(product.ImageFileName))
            {
                <img src="~/uploads/@product.ImageFileName" alt="@product.Title"
                     class="w-full h-48 object-cover rounded mb-3" />
            }
            <h3 class="text-lg font-semibold">@product.Title</h3>
            <p class="text-sm text-gray-600">@product.Description</p>
            <p class="text-green-700 font-bold mt-2">$@product.Price.ToString("F2")</p>
            <p class="text-xs text-gray-400 mt-1">@product.CreatedAt.ToString("g")</p>
        </div>
    }
</div>
@if (!Model.Any())
{
    <p class="text-gray-500 mt-4">No products yet. Add one using the form below.</p>
}